    "@repo/auth": "workspace:*",
    "@repo/db": "workspace:*",
    "@orpc/server": "^1",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "typescript": "catalog:"
  }
}
