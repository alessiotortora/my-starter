{
  "name": "@repo/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "varlock run --path ../.. -- bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
