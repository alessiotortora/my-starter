{
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@repo/typescript-config": "workspace:*",
    "lefthook": "^2.1.5",
    "turbo": "^2",
    "typescript": "catalog:",
    "ultracite": "7.5.9",
    "varlock": "^0.9.0",
    "vitest": "^4.1.5"
  },
  "name": "my-starter",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "env:typegen": "varlock typegen",
    "env:check": "varlock load",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:push": "bun --filter=@repo/db db:push",
    "db:generate": "bun --filter=@repo/db db:generate",
    "db:migrate": "bun --filter=@repo/db db:migrate",
    "db:studio": "bun --filter=@repo/db db:studio",
    "rename": "bun scripts/rename.ts",
    "prepare": "lefthook install && varlock typegen"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "private": true,
  "packageManager": "bun@1.3.12",
  "catalog": {
    "typescript": "^6",
    "react": "^19",
    "react-dom": "^19",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "hono": "^4",
    "vite": "^8",
    "@vitejs/plugin-react": "^6"
  }
}
